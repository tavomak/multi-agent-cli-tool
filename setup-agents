#!/usr/bin/env bash
set -euo pipefail

VERSION="1.1.0"
REPO_RAW="https://raw.githubusercontent.com/tavomak/multi-agent-cli-tool/main"

# ── colors ─────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; BOLD='\033[1m'; NC='\033[0m'
ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }
fail() { echo -e "${RED}✗${NC} $*"; exit 1; }
err()  { echo -e "${RED}✗${NC} $*"; }
bold() { echo -e "${BOLD}$*${NC}"; }
info() { echo -e "  $*"; }
dim()  { echo -e "  - $*"; }

# ── help ───────────────────────────────────────────────────────────────────
usage() {
    cat << EOF
setup-agents v${VERSION}
Single source of truth for multi-AI documentation.

USAGE:
  setup-agents init [PATH] [--all] [--template <name>]
  setup-agents add <adapter>
  setup-agents migrate [PATH] [--dry-run] [--yes]
  setup-agents status [PATH]
  setup-agents undo [PATH]
  setup-agents update
  setup-agents templates
  setup-agents --help | --version

COMMANDS:
  init [PATH]      Set up AGENTS.md structure in PATH (default: current dir)
  add <adapter>    Add a tool adapter symlink to current project
                   Adapters: cursor | windsurf | copilot | zed
  migrate [PATH]   Migrate existing .claude/ subdirs (skills, specs, etc.)
                   Interactive. Auto dry-run if no TTY detected.
  status [PATH]    Show current setup state and validate AGENTS.md
  undo [PATH]      Reverse init: restore symlinks to plain files
  update           Self-upgrade to latest version from GitHub
  templates        List available AGENTS.md templates

OPTIONS:
  --all              Create all tool adapter symlinks
  --template <name>  AGENTS.md template to use (default: default)
  --dry-run          Show what migrate would do without making changes
  --yes              Non-interactive: use defaults in migrate
  --help             Show this help
  --version          Show version

EXAMPLES:
  setup-agents init
  setup-agents init ~/projects/myapp --template node
  setup-agents init --all
  setup-agents status
  setup-agents migrate --yes
  setup-agents undo
  setup-agents update
  setup-agents add cursor
  setup-agents templates
EOF
}

