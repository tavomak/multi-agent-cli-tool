_get_template() {
    local name="${1:-default}"
    case "$name" in
        default) _template_default ;;
        node)    _template_node ;;
        python)  _template_python ;;
        *)       fail "Unknown template: '${name}'. Run 'setup-agents templates' to list available." ;;
    esac
}

cmd_templates() {
    bold "Available templates:"
    echo "  default  — minimal AI instructions (blank)"
    echo "  node     — Node.js / TypeScript project"
    echo "  python   — Python project (ruff, pytest, mypy)"
    echo ""
    echo "Usage: setup-agents init --template <name>"
}

# ── arg parsing ────────────────────────────────────────────────────────────
CMD=""
TARGET_DIR=""
ALL_ADAPTERS=false
DRY_RUN=false
YES=false
ADAPTER=""
TEMPLATE_NAME="default"

while [[ $# -gt 0 ]]; do
    case "$1" in
        init)       CMD="init"; shift ;;
        add)        CMD="add"; shift
                    if [[ -n "${1:-}" && "${1:-}" != --* ]]; then
                        ADAPTER="$1"; shift
                    fi
                    ;;
        migrate)    CMD="migrate"; shift ;;
        status)     CMD="status"; shift ;;
        undo)       CMD="undo"; shift ;;
        update)     CMD="update"; shift ;;
        templates)  CMD="templates"; shift ;;
        --all)      ALL_ADAPTERS=true; shift ;;
        --dry-run)  DRY_RUN=true; shift ;;
        --yes|-y)   YES=true; shift ;;
        --template) shift; TEMPLATE_NAME="${1:-}"; [[ -z "$TEMPLATE_NAME" ]] && fail "--template requires a name"; shift ;;
        --help|-h)  usage; exit 0 ;;
        --version)  echo "setup-agents v${VERSION}"; exit 0 ;;
        -*)         fail "Unknown option: $1" ;;
        *)
            if [[ -z "$TARGET_DIR" ]]; then
                TARGET_DIR="$1"
            else
                fail "Unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -z "$CMD" ]] && { usage; exit 0; }

# ── resolve target directory ───────────────────────────────────────────────
if [[ -z "$TARGET_DIR" ]]; then
    TARGET_DIR="$PWD"
fi

TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" || fail "Directory not found: $TARGET_DIR"

# ── command: add ───────────────────────────────────────────────────────────
cmd_add() {
    [[ -f "AGENTS.md" ]] || fail "No AGENTS.md found. Run 'setup-agents init' first."

    if [[ "$ALL_ADAPTERS" == true && -z "$ADAPTER" ]]; then
        bold "Tool adapters:"
        ADAPTER="cursor";   cmd_add
        ADAPTER="windsurf"; cmd_add
        ADAPTER="copilot";  cmd_add
        ADAPTER="zed";      cmd_add
        return
    fi

    [[ -z "$ADAPTER" ]] && fail "Specify adapter: cursor | windsurf | copilot | zed (or --all)"

    case "$ADAPTER" in
        cursor)
            if [[ -e ".cursorrules" ]]; then
                warn ".cursorrules already exists — skipping"
            else
                ln -s AGENTS.md .cursorrules
                ok "Created .cursorrules → AGENTS.md (Cursor)"
            fi
            ;;
        windsurf)
            if [[ -e ".windsurfrules" ]]; then
                warn ".windsurfrules already exists — skipping"
            else
                ln -s AGENTS.md .windsurfrules
                ok "Created .windsurfrules → AGENTS.md (Windsurf)"
            fi
            ;;
        copilot)
            mkdir -p .github
            if [[ -e ".github/copilot-instructions.md" ]]; then
                warn ".github/copilot-instructions.md already exists — skipping"
            else
                ln -s ../AGENTS.md .github/copilot-instructions.md
                ok "Created .github/copilot-instructions.md → ../AGENTS.md (Copilot)"
            fi
            ;;
        zed)
            mkdir -p .zed
            if [[ -e ".zed/rules.md" ]]; then
                warn ".zed/rules.md already exists — skipping"
            else
                ln -s ../AGENTS.md .zed/rules.md
                ok "Created .zed/rules.md → ../AGENTS.md (Zed)"
            fi
            ;;
        *)
            fail "Unknown adapter: $ADAPTER. Options: cursor | windsurf | copilot | zed"
            ;;
    esac
}

# ── command: init ──────────────────────────────────────────────────────────
cmd_init() {
    bold "setup-agents init → ${TARGET_DIR}"
    echo ""

    cd "$TARGET_DIR"

    # 1. create .agents/ and seed starter files
    if [[ -d ".agents" ]]; then
        warn ".agents/ already exists — skipping"
    else
        mkdir .agents
        ok "Created .agents/"
    fi

    if [[ -f ".agents/mcps.md" ]]; then
        warn ".agents/mcps.md already exists — skipping"
    else
        _mcps_starter > .agents/mcps.md
        ok "Created .agents/mcps.md (MCP + skills registry)"
    fi

    if [[ -f ".agents/pending-work.md" ]]; then
        warn ".agents/pending-work.md already exists — skipping"
    else
        _pending_work_starter "$(basename "$TARGET_DIR")" > .agents/pending-work.md
        ok "Created .agents/pending-work.md (task tracking)"
    fi

    # 2. move all .md files from .claude/ (except CLAUDE.md)
    moved=0
    if [[ -d ".claude" ]]; then
        for f in .claude/*.md .claude/*.MD; do
            [[ -e "$f" ]] || continue
            [[ -L "$f" ]] && { warn "Skipping symlink: $f"; continue; }
            base="$(basename "$f")"
            [[ "$base" == "CLAUDE.md" || "$base" == "CLAUDE.MD" ]] && continue
            target=".agents/$base"
            if [[ -e "$target" ]]; then
                warn "$target already exists — skipping"
            else
                mv "$f" "$target"
                ok "Moved $f → $target"
                ((moved++)) || true
            fi
        done

        # warn if real (non-symlink) subdirectories exist — suggest migrate
        has_subdirs=false
        for d in .claude/*/; do
            [[ -d "$d" ]] && [[ ! -L "$d" ]] && has_subdirs=true && break
        done
        if [[ "$has_subdirs" == true ]]; then
            echo ""
            warn "Subdirectories found in .claude/ (skills, specs, etc.)"
            warn "Run 'setup-agents migrate' to handle them."
        fi
    fi
    [[ $moved -eq 0 ]] && warn "No reference files moved (already done or none found)"

    # 3. create AGENTS.md
    if [[ -e "AGENTS.md" && ! -L "AGENTS.md" ]]; then
        warn "AGENTS.md already exists — skipping"
        warn "Review paths inside AGENTS.md — should reference .agents/ not .claude/"
    elif [[ -L ".claude/CLAUDE.md" ]]; then
        warn ".claude/CLAUDE.md already a symlink — AGENTS.md already set up"
    elif [[ -f ".claude/CLAUDE.md" ]]; then
        cp .claude/CLAUDE.md AGENTS.md
        ok "Created AGENTS.md from .claude/CLAUDE.md"
        warn "Review AGENTS.md — update any paths from .claude/ to .agents/"
    else
        # auto-discover existing rules files before falling back to template
        local discovered=""
        for candidate in ".cursorrules" ".windsurfrules" ".github/copilot-instructions.md"; do
            if [[ -f "$candidate" && ! -L "$candidate" ]]; then
                discovered="$candidate"
                break
            fi
        done

        if [[ -n "$discovered" ]] && [ -t 0 ]; then
            echo ""
            warn "Found existing rules file: $discovered"
            read -r -p "  Use it as AGENTS.md content? [Y/n] " choice
            if [[ ! "$choice" =~ ^[nN]$ ]]; then
                cp "$discovered" AGENTS.md
                ok "Created AGENTS.md from $discovered"
                warn "Review AGENTS.md content — clean up tool-specific formatting if needed"
            else
                _get_template "$TEMPLATE_NAME" > AGENTS.md
                ok "Created AGENTS.md (template: ${TEMPLATE_NAME})"
            fi
        elif [[ -n "$discovered" ]]; then
            warn "Found $discovered but no TTY — using template. Run interactively to use it."
            _get_template "$TEMPLATE_NAME" > AGENTS.md
            ok "Created AGENTS.md (template: ${TEMPLATE_NAME})"
        else
            _get_template "$TEMPLATE_NAME" > AGENTS.md
            ok "Created AGENTS.md (template: ${TEMPLATE_NAME})"
        fi
    fi

    # 4. replace .claude/CLAUDE.md with symlink
    if [[ ! -d ".claude" ]]; then
        mkdir .claude
        ok "Created .claude/"
    fi

    if [[ -L ".claude/CLAUDE.md" ]]; then
        warn ".claude/CLAUDE.md already a symlink — skipping"
    elif [[ -f ".claude/CLAUDE.md" ]]; then
        rm .claude/CLAUDE.md
        ln -s ../AGENTS.md .claude/CLAUDE.md
        ok "Replaced .claude/CLAUDE.md with symlink → ../AGENTS.md"
    else
        ln -s ../AGENTS.md .claude/CLAUDE.md
        ok "Created .claude/CLAUDE.md → ../AGENTS.md"
    fi

    # 5. optional adapters
    if [[ "$ALL_ADAPTERS" == true ]]; then
        echo ""
        bold "Tool adapters:"
        ADAPTER="cursor";   cmd_add
        ADAPTER="windsurf"; cmd_add
        ADAPTER="copilot";  cmd_add
        ADAPTER="zed";      cmd_add
    fi

    echo ""
    ok "Done. Edit AGENTS.md — all tools read it automatically."
    [[ "$ALL_ADAPTERS" == false ]] && echo "   Run with --all to create Cursor/Windsurf/Copilot/Zed adapters."

    # .gitignore tip
    if [[ -f ".gitignore" ]] && grep -q "\.local\.md" .gitignore 2>/dev/null; then
        true
    else
        echo "   Tip: add '.agents/*.local.md' to .gitignore for local-only notes not meant for git."
    fi
}

# ── helper: check single adapter for status output ─────────────────────────
_check_adapter() {
    local path="$1" label="$2"
    if [[ -L "$path" ]]; then
        local target
        target="$(readlink "$path")"
        ok "${label}: ${path} → ${target}"
    elif [[ -f "$path" ]]; then
        warn "${label}: ${path} exists but is not a symlink (has own content)"
    else
        dim "${label}: not configured (setup-agents add $(echo "$label" | tr '[:upper:]' '[:lower:]'))"
    fi
}

# ── command: status ────────────────────────────────────────────────────────
cmd_status() {
    cd "$TARGET_DIR"

    bold "setup-agents status → ${TARGET_DIR}"
    echo ""

    # core files
    echo "Core:"
    if [[ -f "AGENTS.md" && ! -L "AGENTS.md" ]]; then
        ok "AGENTS.md"
    elif [[ -L "AGENTS.md" ]]; then
        warn "AGENTS.md is a symlink (unusual — should be the source file)"
    else
        err "AGENTS.md missing — run 'setup-agents init'"
    fi

    if [[ -d ".agents" ]]; then
        local count
        count="$(find .agents -maxdepth 1 -name '*.md' | wc -l | tr -d ' ')"
        ok ".agents/ (${count} .md files)"
        [[ -f ".agents/mcps.md" ]]          && ok ".agents/mcps.md"          || warn ".agents/mcps.md missing — run 'setup-agents init' to create"
        [[ -f ".agents/pending-work.md" ]] && ok ".agents/pending-work.md"  || warn ".agents/pending-work.md missing — run 'setup-agents init' to create"
    else
        warn ".agents/ not found"
    fi

    if [[ -L ".claude/CLAUDE.md" ]]; then
        local target
        target="$(readlink ".claude/CLAUDE.md")"
        if [[ "$target" == "../AGENTS.md" ]]; then
            ok ".claude/CLAUDE.md → AGENTS.md"
        else
            warn ".claude/CLAUDE.md → ${target} (unexpected target)"
        fi
    elif [[ -f ".claude/CLAUDE.md" ]]; then
        warn ".claude/CLAUDE.md is a plain file — run 'setup-agents init' to convert"
    else
        warn ".claude/CLAUDE.md missing"
    fi

    echo ""
    echo "Adapters:"
    _check_adapter ".cursorrules" "Cursor"
    _check_adapter ".windsurfrules" "Windsurf"
    _check_adapter ".github/copilot-instructions.md" "Copilot"
    _check_adapter ".zed/rules.md" "Zed"

    # validation
    if [[ -f "AGENTS.md" ]]; then
        echo ""
        echo "Validation:"
        local issues=0
        for section in "## Session protocol" "## NEVER DO" "## ALWAYS DO" "## ASK FIRST"; do
            if grep -q "^${section}" AGENTS.md 2>/dev/null; then
                ok "Has '${section}'"
            else
                warn "Missing section '${section}'"
                ((issues++)) || true
            fi
        done

        # check for broken symlinks in .agents/
        local broken=0
        for f in .agents/*; do
            [[ -L "$f" ]] && [[ ! -e "$f" ]] && { warn "Broken symlink: $f"; ((broken++)) || true; }
        done

        [[ $issues -eq 0 && $broken -eq 0 ]] && ok "All checks passed"
    fi
}

# ── command: undo ──────────────────────────────────────────────────────────
cmd_undo() {
    cd "$TARGET_DIR"

    bold "setup-agents undo → ${TARGET_DIR}"
    echo ""

    local undone=0

    # restore .claude/CLAUDE.md from symlink to plain file
    if [[ -L ".claude/CLAUDE.md" ]]; then
        local target
        target="$(readlink ".claude/CLAUDE.md")"
        if [[ "$target" == "../AGENTS.md" ]]; then
            rm ".claude/CLAUDE.md"
            if [[ -f "AGENTS.md" ]]; then
                cp "AGENTS.md" ".claude/CLAUDE.md"
                ok "Restored .claude/CLAUDE.md (copied from AGENTS.md)"
            else
                warn "AGENTS.md not found — .claude/CLAUDE.md removed but not restored"
            fi
            ((undone++)) || true
        else
            warn ".claude/CLAUDE.md points to ${target} — skipping (not managed by setup-agents)"
        fi
    elif [[ -f ".claude/CLAUDE.md" ]]; then
        warn ".claude/CLAUDE.md is already a plain file — nothing to undo"
    fi

    # remove adapter symlinks
    local adapters=(".cursorrules:.cursorrules" ".windsurfrules:.windsurfrules" ".github/copilot-instructions.md:copilot-instructions.md" ".zed/rules.md:rules.md")
    for entry in "${adapters[@]}"; do
        local path="${entry%%:*}"
        if [[ -L "$path" ]]; then
            rm "$path"
            ok "Removed symlink: $path"
            ((undone++)) || true
        fi
    done

    echo ""
    if [[ $undone -eq 0 ]]; then
        warn "Nothing to undo."
    else
        ok "Done. AGENTS.md and .agents/ left in place — remove manually if needed."
    fi
}

# ── command: update ────────────────────────────────────────────────────────
cmd_update() {
    # locate installed binary
    local installed
    if installed="$(command -v setup-agents 2>/dev/null)" && [[ -w "$installed" ]]; then
        : # writable bin in PATH
    elif [[ -x "$0" && -w "$0" ]]; then
        installed="$0"
    else
        fail "Cannot locate writable setup-agents binary. Try: sudo setup-agents update"
    fi

    bold "Checking for updates..."
    echo "  Current: v${VERSION}"
    echo "  Source:  ${REPO_RAW}/setup-agents"
    echo ""

    local tmp
    tmp="$(mktemp)"
    # shellcheck disable=SC2064
    trap "rm -f '$tmp'" EXIT

    curl -fsSL "${REPO_RAW}/setup-agents" -o "$tmp" || fail "Download failed. Check your connection."

    local new_version
    new_version="$(grep '^VERSION=' "$tmp" | head -1 | cut -d'"' -f2)"

    if [[ "$new_version" == "$VERSION" ]]; then
        ok "Already up to date (v${VERSION})."
        return
    fi

    chmod +x "$tmp"
    mv "$tmp" "$installed"
    trap - EXIT
    ok "Updated v${VERSION} → v${new_version} at ${installed}"
}

# ── helper: migrate a subdir from .claude/ to .agents/ + symlink ───────────
_migrate_subdir() {
    local name="$1"
    local src=".claude/${name}"
    local dest=".agents/${name}"

    if [[ -e "$dest" ]]; then
        warn ".agents/${name}/ already exists — skipping"
        return
    fi

    mkdir -p .agents
    mv "$src" "$dest"
    ln -s "../.agents/${name}" ".claude/${name}"
    ok "Moved .claude/${name}/ → .agents/${name}/ + symlink"
}

# ── helper: prompt user with numbered options, return choice ────────────────
_prompt() {
    local prompt="$1"
    local default="$2"
    local choice
    read -r -p "${prompt} [${default}]: " choice
    echo "${choice:-$default}"
}

# ── command: migrate ───────────────────────────────────────────────────────
cmd_migrate() {
    cd "$TARGET_DIR"

    [[ -d ".claude" ]] || fail "No .claude/ directory found. Run from project root or pass PATH."

    # auto dry-run if no TTY and --yes not set
    if ! [ -t 0 ] && [[ "$YES" == false ]]; then
        DRY_RUN=true
        warn "No TTY detected. Running in dry-run mode."
        warn "Run interactively or with --yes for defaults: setup-agents migrate --yes"
        echo ""
    fi

    bold "setup-agents migrate → ${TARGET_DIR}"
    [[ "$DRY_RUN" == true ]] && echo -e "  ${YELLOW}(dry-run — no changes will be made)${NC}"
    [[ "$YES"     == true ]] && echo -e "  ${YELLOW}(--yes — using defaults for all items)${NC}"
    echo ""

    # ── detection phase ──────────────────────────────────────────────────
    local -a items=()
    local -a types=()

    if [[ -f ".claude/settings.json" || -f ".claude/settings.local.json" ]]; then
        items+=("settings"); types+=("settings")
    fi

    local base
    for d in .claude/*/; do
        [[ -d "$d" ]] || continue
        [[ -L "$d" ]] && continue  # skip existing symlinks
        base="$(basename "$d")"
        case "$base" in
            commands) items+=("$base"); types+=("commands") ;;
            specs)    items+=("$base"); types+=("specs") ;;
            *)        items+=("$base"); types+=("unknown") ;;
        esac
    done

    if [[ ${#items[@]} -eq 0 ]]; then
        ok "Nothing to migrate in .claude/ — all clean."
        return
    fi

    # ── report ───────────────────────────────────────────────────────────
    echo "Found in .claude/:"
    local pad
    for i in "${!items[@]}"; do
        case "${types[$i]}" in
            commands) echo -e "  ${YELLOW}!${NC} commands/      → Claude-specific skills. Default: leave in place" ;;
            specs)    echo -e "  ${GREEN}✓${NC} specs/         → Project docs. Default: move to .agents/specs/ + symlink" ;;
            settings) echo -e "  ${YELLOW}!${NC} settings.json  → Config file. Will not touch." ;;
            unknown)
                pad=$(( 14 - ${#items[$i]} ))
                (( pad < 0 )) && pad=0
                echo -e "  ${BOLD}?${NC} ${items[$i]}/${NC}$(printf '%*s' "$pad" '')→ Unknown subdir. Default: skip"
                ;;
        esac
    done
    echo ""

    if [[ "$DRY_RUN" == true ]]; then
        echo "Dry-run complete. No changes made."
        echo "Run interactively: setup-agents migrate"
        echo "Run with defaults: setup-agents migrate --yes"
        return
    fi

    # ── confirm (skip if --yes) ───────────────────────────────────────────
    if [[ "$YES" == false ]]; then
        read -r -p "Proceed interactively? [y/N] " confirm
        [[ "$confirm" =~ ^[yY]$ ]] || { echo "Aborted."; exit 0; }
        echo ""
    fi

    # ── interactive per item ─────────────────────────────────────────────
    local item type choice
    for i in "${!items[@]}"; do
        item="${items[$i]}"
        type="${types[$i]}"

        case "$type" in
            settings)
                warn "settings.json — skipping (never modified by setup-agents)"
                ;;

            commands)
                if [[ "$YES" == true ]]; then
                    ok "commands/ — left in place (default)"
                else
                    echo ""
                    bold "commands/ (Claude Code skills):"
                    info "[1] Leave in .claude/commands/ (recommended — Claude-specific)"
                    info "[2] Move to .agents/commands/ + symlink"
                    info "[3] Skip"
                    choice=$(_prompt "Choice" "1")
                    case "$choice" in
                        1) ok "commands/ — left in place" ;;
                        2) _migrate_subdir "commands" ;;
                        3) warn "commands/ — skipped" ;;
                        *) warn "Invalid choice — skipping" ;;
                    esac
                fi
                ;;

            specs)
                if [[ "$YES" == true ]]; then
                    _migrate_subdir "specs"
                else
                    echo ""
                    bold "specs/ (project docs):"
                    info "[1] Move to .agents/specs/ + symlink (recommended)"
                    info "[2] Leave in .claude/specs/"
                    info "[3] Skip"
                    choice=$(_prompt "Choice" "1")
                    case "$choice" in
                        1) _migrate_subdir "specs" ;;
                        2) ok "specs/ — left in place" ;;
                        3) warn "specs/ — skipped" ;;
                        *) warn "Invalid choice — skipping" ;;
                    esac
                fi
                ;;

            unknown)
                if [[ "$YES" == true ]]; then
                    warn "${item}/ — skipped (default for unknown)"
                else
                    echo ""
                    bold "${item}/:"
                    info "[1] Move to .agents/${item}/ + symlink"
                    info "[2] Leave in .claude/${item}/"
                    info "[3] Skip (recommended — unknown purpose)"
                    choice=$(_prompt "Choice" "3")
                    case "$choice" in
                        1) _migrate_subdir "$item" ;;
                        2) ok "${item}/ — left in place" ;;
                        3) warn "${item}/ — skipped" ;;
                        *) warn "Invalid choice — skipping" ;;
                    esac
                fi
                ;;
        esac
    done

    echo ""
    ok "Migration complete."
}

# ── dispatch ───────────────────────────────────────────────────────────────
case "$CMD" in
    init)      cmd_init ;;
    add)       cd "$TARGET_DIR"; cmd_add ;;
    migrate)   cmd_migrate ;;
    status)    cmd_status ;;
    undo)      cmd_undo ;;
    update)    cmd_update ;;
    templates) cmd_templates ;;
esac
